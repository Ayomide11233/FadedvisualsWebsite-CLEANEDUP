# ============================================================
# ENVIRONMENT CONFIGURATION — Copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# Security
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# Database
DATABASE_URL=sqlite:///./faded_visuals.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/faded_visuals

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Ollama / AI
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2

# Rate limiting
CHAT_RATE_LIMIT=10/minute
AUTH_RATE_LIMIT=5/minute

# Environment
ENVIRONMENT=development
